# GitHub — classic token with public_repo scope is enough for public repos
GITHUB_TOKEN=ghp_...

# LLM (BYOK) — DeepSeek is the default provider
DEEPSEEK_API_KEY=sk-...

# Optional overrides
# REPOMIND_PROVIDER=deepseek        # deepseek | openai | anthropic | openai-compatible
# REPOMIND_MODEL=deepseek-chat
# REPOMIND_API_KEY=                 # overrides the provider-specific key var
# REPOMIND_BASE_URL=                # required for openai-compatible (e.g. http://localhost:11434/v1)
# REPOMIND_CONCURRENCY=4
